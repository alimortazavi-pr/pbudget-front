# ============================================
# Paradise Desk / میز پردیس — Frontend (Next.js)
# ============================================
# لوکال:  cp .env.example .env.local
# Vercel: همین متغیرها را در Project → Settings → Environment Variables بگذار
# ============================================

# --------------------------------------------
# API بک‌اند (حتماً با /v1 تمام شود)
# --------------------------------------------
# در `pnpm dev` / `npm run dev` خودکار از http://localhost:7701/v1 استفاده می‌شود.
# فقط برای build/production لازم است:
NEXT_PUBLIC_API_URL=https://api.pdesk.ir/v1

# اختیاری — اگر پورت بک‌اند لوکال فرق دارد:
# NEXT_PUBLIC_DEV_API_URL=http://localhost:7701/v1

# برای رندر سمت سرور Next.js در production
INTERNAL_API_URL=https://api.pdesk.ir/v1

# --------------------------------------------
# آدرس عمومی سایت (دامنه اصلی — canonical / metadata)
# --------------------------------------------
# لوکال:
NEXT_PUBLIC_SITE_URL=http://localhost:7711

# Production — دامنه اصلی جدید:
# NEXT_PUBLIC_SITE_URL=https://pdesk.ir
# NEXT_PUBLIC_SITE_URL=https://www.pdesk.ir

# Legacy (هنوز روی سرور فعال — نیازی به env جدا نیست؛ CORS بک‌اند هر دو را می‌پذیرد):
# https://pbudget.ir
# https://www.pbudget.ir

# --------------------------------------------
# تلگرام (اختیاری)
# --------------------------------------------
# fallback اگر API در پاسخ لینک، botUsername ندهد
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=paradisebudget_bot

# ============================================
# راهنمای Vercel / PM2
# ============================================
# Root Directory: pbudget-front
# Build Command:   pnpm build  (یا npm run build)
# Install Command: pnpm install
#
# Environment Variables (Production + Preview):
#   NEXT_PUBLIC_API_URL=https://api.pdesk.ir/v1
#   INTERNAL_API_URL=https://api.pdesk.ir/v1
#   NEXT_PUBLIC_SITE_URL=https://pdesk.ir
#   NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=YourBotName
#
# دامنه‌های legacy (pbudget.ir) همچنان کار می‌کنند — CORS در pbudget-back/src/config/cors-origins.ts
